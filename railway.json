{
  "project": "MainProject",
  "services": [
    {
      "name": "api",
      "provider": "node",
      "rootDirectory": "./",
      "start": "node index.js",
      "env": [
        "NODE_ENV",
        "PORT",
        "SUPABASE_URL",
        "SUPABASE_SERVICE_ROLE_KEY",
        "SUPABASE_ANON_KEY",
        "SUPABASE_JWT_SECRET",
        "DATABASE_URL",
        "DATABASE_POOLER_URL",
        "CORS_ALLOWED_ORIGINS",
        "DEV_FALLBACK",
        "JWT_ACCESS_SECRET",
        "JWT_REFRESH_SECRET",
        "COOKIE_DOMAIN",
        "BROADCAST_API_KEY"
      ]
    },
    {
      "name": "frontend",
      "provider": "static",
      "rootDirectory": "./",
      "build": "npm run build:client",
      "publish": "dist",
      "env": [
        "VITE_API_BASE_URL",
        "VITE_WS_URL",
        "VITE_ENABLE_WS",
        "VITE_SUPABASE_URL",
        "VITE_SUPABASE_ANON_KEY"
      ]
    }
  ]
}
