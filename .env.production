# .env.production — Vite build-time defaults for the production frontend bundle.
#
# ✅ SAFE TO COMMIT — contains only PUBLIC values:
#    - VITE_SUPABASE_ANON_KEY is the public anon key (RLS-scoped, intentionally client-facing)
#    - All other values are public URLs
#
# ⚠️  Never put SUPABASE_SERVICE_ROLE_KEY, JWT_SECRET, or any server secret here.
#
# Railway/Netlify/Vercel env vars set in the dashboard override these at build time.
# Set them in the hosting dashboard to avoid re-deploying when values change.

# ── API ──────────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=https://api.the-huddle.co/api

# ── WebSocket ─────────────────────────────────────────────────────────────────
VITE_ENABLE_WS=true
VITE_WS_URL=wss://api.the-huddle.co/ws

# ── Supabase (public anon key — safe to expose) ───────────────────────────────
VITE_SUPABASE_URL=https://eprsgmfzqjptfywoecuy.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImVwcnNnbWZ6cWpwdGZ5d29lY3V5Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzE1NDM2MzcsImV4cCI6MjA4NzExOTYzN30.lbvywGKDcBJM2ZU9n_-9l4kcRcZNxSExsGv2CphS56o

# ── Storage buckets ───────────────────────────────────────────────────────────
VITE_SUPABASE_DOCUMENTS_BUCKET=course-resources
VITE_SUPABASE_VIDEOS_BUCKET=course-videos

# ── App flags ─────────────────────────────────────────────────────────────────
VITE_APP_ENV=production
VITE_DEPLOY_CONTEXT=production
VITE_SW_ENABLED=true
# VITE_ALLOW_DEFAULT_COURSES intentionally absent — defaults to false in production
